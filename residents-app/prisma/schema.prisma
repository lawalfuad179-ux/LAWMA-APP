datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum ComplaintStatus {
  SUBMITTED
  IN_REVIEW
  ASSIGNED
  RESOLVED
}

enum BillStatus {
  PENDING
  PAID
  OVERDUE
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REVERSED
}

enum CollectionStatus {
  SCHEDULED
  DELAYED
  MISSED
  COMPLETED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationType {
  COLLECTION_REMINDER
  DELAYED_PICKUP
  COMPLAINT_UPDATE
  PAYMENT_CONFIRMATION
  ANNOUNCEMENT
  RECYCLING_REWARD
  ENVIRONMENTAL_REMINDER
}

enum RecycleActivityStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum PointTransactionType {
  EARNED_RECYCLING
  EARNED_BILL_PAYMENT
  EARNED_CENTER_DROPOFF
  REDEEMED_BILL_DISCOUNT
  BONUS_FIRST_SCAN
  ADMIN_ADJUSTMENT
}

// Buy-back materials accepted over the counter at a collection centre.
// Deliberately narrower than the AI scanner's categories (src/lib/ai.ts):
// a centre only pays for what it can resell.
enum DropOffMaterial {
  PLASTIC
  PAPER
  CARDBOARD
  METAL
  GLASS
}

enum DropOffStatus {
  CONFIRMED
  FLAGGED // over a cap / outlier — credited but queued for supervisor review
  VOIDED  // reversed by a supervisor
}

// How the resident took their payout at the counter. CREDIT lands in the app
// wallet (and auto-applies to their waste bill); CASH is handed over
// physically — recorded so every cash naira reconciles to an operator + receipt.
enum PayoutMethod {
  CREDIT
  CASH
}

model Resident {
  id                     String        @id @default(uuid())
  phoneNumber            String?       @unique @map("phone_number")
  email                  String?       @unique @map("email")
  name                   String?       @map("name")
  address                String?       @map("address")
  lga                    String?       @map("lga")
  latitude               Float?        @map("latitude")
  longitude              Float?        @map("longitude")
  passwordHash           String?       @map("password_hash")
  avatarUrl             String?       @map("avatar_url")
  onboardingVersion      Int           @default(0) @map("onboarding_version")
  onboardingCompletedAt  DateTime?     @map("onboarding_completed_at")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  sessions               Session[]
  complaints             Complaint[]
  bills                  Bill[]
  payments               Payment[]
  binOrders              BinOrder[]
  notifications          Notification[]
  recycleActivities      RecycleActivity[]
  pointTransactions      PointTransaction[]
  rewardAccount          RewardAccount?
  dropOffs               DropOff[]

  @@index([lga])
  @@map("residents")
}

model Session {
  id         String   @id @default(uuid())
  residentId String   @map("resident_id")
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  token      String   @unique @map("token")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("sessions")
}

model OtpCode {
  id          String   @id @default(uuid())
  phoneNumber String   @map("phone_number")
  code        String   @map("code")
  expiresAt   DateTime @map("expires_at")
  isUsed      Boolean  @default(false) @map("is_used")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([phoneNumber])
  @@map("otp_codes")
}

model PspOperator {
  id           String               @id @default(uuid())
  name         String               @map("name")
  contactPhone String?              @map("contact_phone")
  email        String?              @map("email")
  zone         String               @map("zone")
  lga          String               @map("lga")
  createdAt    DateTime             @default(now()) @map("created_at")
  schedules    CollectionSchedule[]

  @@index([lga])
  @@map("psp_operators")
}

model CollectionSchedule {
  id            String           @id @default(uuid())
  lga           String           @map("lga")
  dayOfWeek     Int              @map("day_of_week") // 0 = Sunday, 6 = Saturday
  windowStart   String           @map("window_start") // e.g. "08:00"
  windowEnd     String           @map("window_end") // e.g. "12:00"
  status        CollectionStatus @default(SCHEDULED) @map("status")
  delayReason   String?          @map("delay_reason")
  nextCollectionDate DateTime?   @map("next_collection_date")
  pspOperatorId String           @map("psp_operator_id")
  pspOperator   PspOperator      @relation(fields: [pspOperatorId], references: [id], onDelete: Restrict)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@unique([lga, dayOfWeek])
  @@index([lga])
  @@index([status])
  @@map("collection_schedules")
}

model Complaint {
  id          String          @id @default(uuid())
  ticketId    String          @unique @map("ticket_id") // Human-readable, e.g. "LW-20250602-A3X9"
  residentId  String          @map("resident_id")
  resident    Resident        @relation(fields: [residentId], references: [id], onDelete: Restrict)
  issueType   String          @map("issue_type") // e.g. "MISSED_PICKUP", "ILLEGAL_DUMPING"
  lga         String          @map("lga")
  area        String          @map("area")
  address     String          @map("address")
  description String?         @map("description")
  status      ComplaintStatus @default(SUBMITTED) @map("status")
  latitude    Float?          @map("latitude")
  longitude   Float?          @map("longitude")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  images      ComplaintImage[]

  @@index([residentId])
  @@index([lga, status])
  @@index([lga, area, issueType, status])
  @@index([createdAt])
  @@index([ticketId])
  @@map("complaints")
}

model ComplaintImage {
  id          String    @id @default(uuid())
  complaintId String    @map("complaint_id")
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  url         String    @map("url")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("complaint_images")
}

model Bill {
  id           String     @id @default(uuid())
  residentId   String     @map("resident_id")
  resident     Resident   @relation(fields: [residentId], references: [id], onDelete: Restrict)
  amountKobo   Int        @map("amount_kobo")
  discountKobo Int        @default(0) @map("discount_kobo")
  dueDate      DateTime   @map("due_date")
  periodStart  DateTime   @map("period_start")
  periodEnd    DateTime   @map("period_end")
  status       BillStatus @default(PENDING) @map("status")
  createdAt    DateTime   @default(now()) @map("created_at")
  payments     Payment[]

  @@index([residentId])
  @@index([residentId, status])
  @@index([dueDate])
  @@map("bills")
}

model Payment {
  id               String        @id @default(uuid())
  billId           String        @map("bill_id")
  bill             Bill          @relation(fields: [billId], references: [id], onDelete: Restrict)
  residentId       String        @map("resident_id")
  resident         Resident      @relation(fields: [residentId], references: [id], onDelete: Restrict)
  amountKobo       Int           @map("amount_kobo")
  currency         String        @default("NGN") @map("currency")
  status           PaymentStatus @default(PENDING) @map("status")
  txRef            String        @unique @map("tx_ref")
  gatewayReference         String?       @unique @map("gateway_reference")
  flutterwaveTransactionId String?       @map("flutterwave_transaction_id")
  verifiedAt               DateTime?     @map("verified_at")
  receiptNumber            String?       @unique @map("receipt_number")
  paidAt                   DateTime?     @map("paid_at")
  createdAt                DateTime      @default(now()) @map("created_at")

  @@index([txRef])
  @@index([residentId])
  @@index([residentId, status])
  @@map("payments")
}

model BinOrder {
  id              String        @id @default(uuid())
  residentId      String        @map("resident_id")
  resident        Resident      @relation(fields: [residentId], references: [id], onDelete: Restrict)
  binType         String        @map("bin_type")
  binLabel        String        @map("bin_label")
  quantity        Int           @map("quantity")
  amountKobo      Int           @map("amount_kobo")
  deliveryAddress String        @map("delivery_address")
  status          PaymentStatus @default(PENDING) @map("status")
  txRef           String        @unique @map("tx_ref")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([txRef])
  @@index([residentId])
  @@map("bin_orders")
}

model Notification {
  id          String           @id @default(uuid())
  residentId  String           @map("resident_id")
  resident    Resident         @relation(fields: [residentId], references: [id], onDelete: Cascade)
  title       String           @map("title")
  body        String           @map("body")
  type        NotificationType @map("type")
  referenceId String?          @map("reference_id") // Links to complaint/payment/schedule ID
  isRead      Boolean          @default(false) @map("is_read")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([residentId])
  @@index([residentId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model EmailOutbox {
  id         String      @id @default(cuid())
  recipient  String      @map("recipient")
  subject    String      @map("subject")
  template   String      @map("template")
  payload    Json        @map("payload")
  status     EmailStatus @default(PENDING) @map("status")
  attempts   Int         @default(0) @map("attempts")
  lastError  String?     @map("last_error")
  sentAt     DateTime?   @map("sent_at")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@index([recipient])
  @@map("email_outbox")
}

model RecycleActivity {
  id           String                @id @default(uuid())
  residentId   String                @map("resident_id")
  resident     Resident              @relation(fields: [residentId], references: [id], onDelete: Cascade)
  imageUrl     String                @map("image_url")
  aiReport     Json                  @map("ai_report")
  pointsEarned Int                   @default(0) @map("points_earned")
  status       RecycleActivityStatus @default(PENDING) @map("status")
  confirmedAt  DateTime?             @map("confirmed_at")
  imageHash    String?               @map("image_hash")
  contentHash  String?               @map("content_hash")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  pointTransactions PointTransaction[]

  @@index([residentId])
  @@index([residentId, status])
  @@index([residentId, status, confirmedAt])
  @@index([residentId, imageHash])
  @@index([residentId, contentHash])
  @@map("recycle_activities")
}

model RewardAccount {
  id            String   @id @default(uuid())
  residentId    String   @unique @map("resident_id")
  resident      Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  balance       Int      @default(0) @map("balance")
  totalEarned   Int      @default(0) @map("total_earned")
  totalRedeemed Int      @default(0) @map("total_redeemed")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("reward_accounts")
}

model PointTransaction {
  id          String               @id @default(uuid())
  residentId  String               @map("resident_id")
  resident    Resident             @relation(fields: [residentId], references: [id], onDelete: Cascade)
  amount      Int                  @map("amount")
  type        PointTransactionType @map("type")
  description String               @map("description")
  activityId  String?              @map("activity_id")
  activity    RecycleActivity?     @relation(fields: [activityId], references: [id], onDelete: SetNull)
  billId      String?              @map("bill_id")
  dropOffId   String?              @map("drop_off_id")
  dropOff     DropOff?             @relation(fields: [dropOffId], references: [id], onDelete: SetNull)
  createdAt   DateTime             @default(now()) @map("created_at")

  @@index([residentId])
  @@index([residentId, createdAt])
  @@map("point_transactions")
}

model NotificationPreference {
  id                       String   @id @default(cuid())
  residentId               String   @unique @map("resident_id")
  emailComplaintUpdates         Boolean  @default(true) @map("email_complaint_updates")
  emailPaymentReceipts          Boolean  @default(true) @map("email_payment_receipts")
  emailCollectionReminders      Boolean  @default(true) @map("email_collection_reminders")
  emailAnnouncements            Boolean  @default(false) @map("email_announcements")
  emailEnvironmentalReminders   Boolean  @default(true) @map("email_environmental_reminders")
  smsComplaintUpdates           Boolean  @default(true) @map("sms_complaint_updates")
  smsCollectionReminders        Boolean  @default(true) @map("sms_collection_reminders")
  smsDelayedPickup              Boolean  @default(true) @map("sms_delayed_pickup")
  smsEnvironmentalReminders     Boolean  @default(true) @map("sms_environmental_reminders")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}

// ─── Collection centres (buy-back) ────────────────────────────────────────
// A staffed facility where residents drop off sorted recyclables, staff weigh
// them, and the resident is credited. Physical staffing is the primary
// anti-abuse control; see src/lib/dropoff-guard.ts for the software layer.

// A facility is either a buy-back counter (Module A) or a transfer station
// with a weighbridge (Module B). Same staffing/auth model either way.
enum CenterKind {
  BUYBACK
  TRANSFER_STATION
}

model CollectionCenter {
  id        String     @id @default(uuid())
  name      String     @map("name")
  address   String     @map("address")
  lga       String     @map("lga")
  kind      CenterKind @default(BUYBACK) @map("kind")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")

  operators   CenterOperator[]
  dropOffs    DropOff[]
  weighEvents WeighEvent[]

  @@index([lga])
  @@map("collection_centers")
}

model CenterOperator {
  id           String           @id @default(uuid())
  name         String           @map("name")
  staffCode    String           @unique @map("staff_code")
  passcodeHash String           @map("passcode_hash")
  centerId     String           @map("center_id")
  center       CollectionCenter @relation(fields: [centerId], references: [id], onDelete: Restrict)
  isActive     Boolean          @default(true) @map("is_active")
  createdAt    DateTime         @default(now()) @map("created_at")

  sessions    CenterSession[]
  dropOffs    DropOff[]
  weighEvents WeighEvent[]

  @@index([centerId])
  @@map("center_operators")
}

model CenterSession {
  id         String         @id @default(uuid())
  operatorId String         @map("operator_id")
  operator   CenterOperator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  token      String         @unique @map("token")
  expiresAt  DateTime       @map("expires_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  @@map("center_sessions")
}

// Buy-back price per material, in kobo per kg. Rates live in the DB rather
// than in code so LAWMA can reprice without a redeploy.
model MaterialRate {
  id         String          @id @default(uuid())
  material   DropOffMaterial @unique @map("material")
  koboPerKg  Int             @map("kobo_per_kg")
  isActive   Boolean         @default(true) @map("is_active")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  @@map("material_rates")
}

// One VISIT to the counter: a person, a sack, one handover, one payment.
//
// A resident who sorted their waste properly arrives with several materials.
// That is one visit with several lines — not several visits — otherwise the
// re-entry guard flags the best-behaved residents, the queue pays for repeated
// lookups, and "residents served today" counts sacks instead of people.
model DropOff {
  id             String           @id @default(uuid())
  centerId       String           @map("center_id")
  center         CollectionCenter @relation(fields: [centerId], references: [id], onDelete: Restrict)
  operatorId     String           @map("operator_id")
  operator       CenterOperator   @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  residentId     String           @map("resident_id")
  resident       Resident         @relation(fields: [residentId], references: [id], onDelete: Cascade)

  totalWeightGrams Int            @map("total_weight_grams")
  totalAmountKobo  Int            @map("total_amount_kobo")
  pointsAwarded    Int            @map("points_awarded")
  payoutMethod     PayoutMethod   @default(CREDIT) @map("payout_method")

  status         DropOffStatus    @default(CONFIRMED) @map("status")
  flagReason     String?          @map("flag_reason")
  receiptCode    String           @unique @map("receipt_code")
  createdAt      DateTime         @default(now()) @map("created_at")

  lines             DropOffLine[]
  pointTransactions PointTransaction[]

  @@index([residentId])
  @@index([residentId, createdAt])
  @@index([centerId, createdAt])
  @@index([operatorId, createdAt])
  @@index([status])
  @@map("drop_offs")
}

// One material weighed within a visit. Immutable financial record: the rate
// applied is copied onto the line so a later reprice never rewrites history.
// Kept per-material (rather than folded into the visit total) because LAWMA
// needs to know how much metal a centre actually bought.
model DropOffLine {
  id            String          @id @default(uuid())
  dropOffId     String          @map("drop_off_id")
  dropOff       DropOff         @relation(fields: [dropOffId], references: [id], onDelete: Cascade)

  material      DropOffMaterial @map("material")
  weightGrams   Int             @map("weight_grams")
  rateKoboPerKg Int             @map("rate_kobo_per_kg")
  amountKobo    Int             @map("amount_kobo")

  // One line per material per visit: two sacks of plastic are summed at the
  // counter, which keeps the receipt readable and the tally unambiguous.
  @@unique([dropOffId, material])
  @@index([dropOffId])
  @@index([material])
  @@map("drop_off_lines")
}

// ─── Transfer stations (weighbridge, Module B) ─────────────────────────────
// Tricycle compactors collect door-to-door (residents pay PAYG at the kerb —
// outside this system). Each tricycle carries an RFID tag and a prepaid
// wallet; the weighbridge detects the tag, weighs the load, and auto-docks a
// tipping fee from the wallet. Ebute-Ero model.

enum WeighEventStatus {
  SETTLED
  FLAGGED_NEGATIVE
  VOID
}

enum TricycleTxnType {
  TOPUP
  TIPPING_FEE
  ADJUSTMENT
}

model Tricycle {
  id                String   @id @default(uuid())
  rfidTag           String   @unique @map("rfid_tag")
  plateNumber       String   @map("plate_number")
  operatorName      String   @map("operator_name")
  // Fleet operators have no app account; SMS to this number is their
  // channel for fee, arrears and top-up notices.
  contactPhone      String?  @map("contact_phone")
  zone              String   @map("zone")
  // Prepaid balance in kobo. May go negative: a loaded tricycle at the bridge
  // is never turned away — the event settles, gets flagged, and the debt shows
  // until the next top-up. Every movement has a matching ledger row.
  walletBalanceKobo Int      @default(0) @map("wallet_balance_kobo")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  weighEvents        WeighEvent[]
  walletTransactions TricycleWalletTransaction[]

  @@index([zone])
  @@map("tricycles")
}

// Tipping fee in kobo per kg. In the DB, not code, so LAWMA can reprice
// without a redeploy — same contract as MaterialRate.
model TippingRate {
  id        String   @id @default(uuid())
  koboPerKg Int      @map("kobo_per_kg")
  isActive  Boolean  @default(true) @map("is_active")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tipping_rates")
}

// One pass over the bridge. Immutable financial record: the rate in force is
// copied onto the event so a later reprice never rewrites what was charged.
model WeighEvent {
  id               String           @id @default(uuid())
  tricycleId       String           @map("tricycle_id")
  tricycle         Tricycle         @relation(fields: [tricycleId], references: [id], onDelete: Restrict)
  stationId        String           @map("station_id")
  station          CollectionCenter @relation(fields: [stationId], references: [id], onDelete: Restrict)
  operatorId       String           @map("operator_id")
  operator         CenterOperator   @relation(fields: [operatorId], references: [id], onDelete: Restrict)

  grossWeightGrams Int              @map("gross_weight_grams")
  rateKoboPerKg    Int              @map("rate_kobo_per_kg")
  feeKobo          Int              @map("fee_kobo")
  balanceAfterKobo Int              @map("balance_after_kobo")

  status           WeighEventStatus @default(SETTLED) @map("status")
  flagReason       String?          @map("flag_reason")
  receiptCode      String           @unique @map("receipt_code")
  createdAt        DateTime         @default(now()) @map("created_at")

  walletTransaction TricycleWalletTransaction?

  @@index([tricycleId, createdAt])
  @@index([stationId, createdAt])
  @@index([status])
  @@map("weigh_events")
}

// Signed movement on a tricycle wallet: TOPUP positive, TIPPING_FEE negative.
// balanceAfterKobo is the wallet's value the instant this row was written, so
// the ledger replays to the current balance without trusting the denormalised
// field on Tricycle.
model TricycleWalletTransaction {
  id               String          @id @default(uuid())
  tricycleId       String          @map("tricycle_id")
  tricycle         Tricycle        @relation(fields: [tricycleId], references: [id], onDelete: Restrict)
  type             TricycleTxnType @map("type")
  amountKobo       Int             @map("amount_kobo")
  balanceAfterKobo Int             @map("balance_after_kobo")
  weighEventId     String?         @unique @map("weigh_event_id")
  weighEvent       WeighEvent?     @relation(fields: [weighEventId], references: [id], onDelete: Restrict)
  operatorId       String?         @map("operator_id")
  note             String?         @map("note")
  createdAt        DateTime        @default(now()) @map("created_at")

  @@index([tricycleId, createdAt])
  @@map("tricycle_wallet_transactions")
}
